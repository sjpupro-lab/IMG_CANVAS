build/
build_demo/
*.o
*.exe
*.ppm

# Wikipedia dumps and extracted text (download via data/download_*.ps1)
spatial_ai/data/*.bz2
spatial_ai/data/*.xml
spatial_ai/data/*.tar.gz
spatial_ai/data/extracted_*/
spatial_ai/data/stsbenchmark/
spatial_ai/data/wiki_[0-9]*
spatial_ai/data/wiki_*.txt
spatial_ai/data/sample_*.txt
spatial_ai/data/stsb.tsv
spatial_ai/data/stsb_sample.tsv
spatial_ai/data/sample_test.txt
